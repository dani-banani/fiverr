      </div>
      <div class="form-group">
        <label class="form-label">Extended Deadline (days from now)</label>
        <input type="number" class="form-input" value="5" min="1" />
      </div>
      <div style="display:flex;gap:10px;margin-top:0.5rem;">
        <button class="btn btn-outline" style="flex:1;" onclick="closeModal('redo-modal')">Cancel</button>
        <button class="btn btn-amber" style="flex:2;" onclick="confirmRedo()">🔄 Send Revision Request</button>
      </div>
    </div>
  </div>
</div>

<!-- ===================== REJECT MODAL ===================== -->
<div class="modal-overlay" id="reject-modal">
  <div class="modal">
    <div class="modal-head">
      <h2>Reject Job</h2>
      <button class="close-btn" onclick="closeModal('reject-modal')">×</button>
    </div>
    <div class="modal-body">
      <div class="info-box red">
        <div class="icon">⛔</div>
        <p>Rejecting the job will <strong>refund the full escrow amount to your wallet</strong>. The freelancer will not be paid. This action cannot be undone — use only if the work is completely unacceptable.</p>
      </div>
      <div class="form-group">
        <label class="form-label">Reason for Rejection</label>
        <textarea class="form-textarea" style="min-height:100px;" placeholder="Explain why the work is being rejected..."></textarea>
      </div>
      <div style="display:flex;gap:10px;margin-top:0.5rem;">
        <button class="btn btn-outline" style="flex:2;" onclick="closeModal('reject-modal')">Go Back</button>
        <button class="btn btn-danger" style="flex:1;" onclick="confirmReject()">Reject & Refund</button>
      </div>
    </div>
  </div>
</div>

<div class="toast hidden" id="toast">
  <span class="toast-icon" id="toast-icon">✅</span>
  <span id="toast-msg">Action completed</span>
</div>

<script>
  let currentRole = 'client';
  let currentJobIdx = 0;
  let countdownInterval;

  const jobs = [
    { title: 'DeFi Dashboard UI Design', amount: '$2,400', days: 12, progress: 15, applicants: '5 total', status: 'hiring' },
    { title: 'Smart Contract Audit — ERC-20', amount: '$3,200', days: 3, progress: 60, applicants: '1 hired', status: 'review' },
    { title: 'Blockchain Backend API', amount: '$1,800', days: 14, progress: 10, applicants: '1 hired', status: 'active' },
    { title: 'NFT Marketplace Frontend', amount: '$1,050', days: 0, progress: 100, applicants: 'Completed', status: 'done' },
  ];

  function switchRole(role, e) {
    currentRole = role;
    document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
    e.target.classList.add('active');
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    document.getElementById('view-' + role).classList.add('active');
    if (role === 'client') {
      document.getElementById('nav-username').textContent = 'Alex Chen';
      document.getElementById('nav-avatar').textContent = 'AC';
    } else {
      document.getElementById('nav-username').textContent = 'Jamie Liu';
      document.getElementById('nav-avatar').textContent = 'JL';
    }
  }

  function selectJob(el, idx) {
    document.querySelectorAll('.job-card').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
    currentJobIdx = idx;
    const job = jobs[idx];
    document.getElementById('escrow-val').textContent = job.amount;
    document.getElementById('escrow-sub').textContent = job.title;
    document.getElementById('escrow-progress').style.width = job.progress + '%';
    startCountdown(job.days);

    const reviewPanel = document.getElementById('review-panel');

    if (job.status === 'review') {
      reviewPanel.style.display = 'block';
      document.getElementById('countdown-label').textContent = '3-day review window remaining';
    } else {
      reviewPanel.style.display = 'none';
      document.getElementById('countdown-label').textContent = 'Auto-release countdown';
    }
  }

  function startCountdown(days) {
    clearInterval(countdownInterval);
    let totalSecs = days * 86400 + Math.floor(Math.random() * 86400);
    function update() {
      const d = Math.floor(totalSecs / 86400);
      const h = Math.floor((totalSecs % 86400) / 3600);
      const m = Math.floor((totalSecs % 3600) / 60);
      const el = document.getElementById('countdown-display');
      if (el) el.textContent = (d > 0 ? d + 'd ' : '') + String(h).padStart(2,'0') + 'h ' + String(m).padStart(2,'0') + 'm';
      if (totalSecs > 0) totalSecs--;
    }
    update();
    countdownInterval = setInterval(update, 60000);
  }

  function openPostJob() { document.getElementById('post-job-modal').classList.add('open'); }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }

  function updateLockPreview(val) {
    const v = parseFloat(val) || 0;
    const fee = v * 0.03;
    const total = v + fee;
    document.getElementById('breakdown-pay').textContent = '$' + v.toFixed(2);
    document.getElementById('breakdown-fee').textContent = '$' + fee.toFixed(2);
    document.getElementById('breakdown-total').textContent = '$' + total.toFixed(2);
  }

  function postJob() {
    closeModal('post-job-modal');
    showToast('🔒 Job posted! Funds locked in escrow.', '🔒');
  }

  function openApply(title, pay) {
    document.getElementById('apply-job-title').textContent = title;
    document.getElementById('apply-job-pay').textContent = pay;
    document.getElementById('apply-escrow-amt').textContent = pay;
    document.getElementById('apply-modal').classList.add('open');
  }

  function submitApplication() {
    closeModal('apply-modal');
    const title = document.getElementById('apply-job-title').textContent;
    const pay = document.getElementById('apply-job-pay').textContent;
    const list = document.getElementById('my-applications-list');
    const div = document.createElement('div');
    div.className = 'app-row';
    div.innerHTML = `
      <div style="width:36px;height:36px;border-radius:8px;background:rgba(251,191,36,0.2);display:flex;align-items:center;justify-content:center;font-size:0.75rem;color:var(--amber);">⏳</div>
      <div class="app-row-info"><div class="app-row-title">${title}</div><div class="app-row-company">New Application</div></div>
      <div class="app-row-pay">${pay}</div>
      <span class="badge badge-pending">Pending</span>
    `;
    list.insertBefore(div, list.firstChild);
    const cnt = document.getElementById('fl-app-count');
    cnt.textContent = parseInt(cnt.textContent) + 1;
    showToast('Application submitted! 🎉', '✅');
  }

  function openSubmitWork(title, pay) {
    document.getElementById('submit-job-title').textContent = title;
    document.getElementById('submit-job-pay').textContent = pay;
    document.getElementById('submit-work-modal').classList.add('open');
  }

  function confirmSubmitWork() {
    closeModal('submit-work-modal');
    // Update freelancer tracker
    document.getElementById('fl-escrow-sub').textContent = 'NFT Marketplace Design · Awaiting client review';
    document.getElementById('fl-timer-label').textContent = 'Client review window — 3 days';
    document.getElementById('fl-timer').textContent = '03d 00h 00m';
    // Update timeline step 3
    const tl = document.getElementById('fl-timeline');
    const steps = tl.querySelectorAll('.timeline-step');
    steps[2].querySelector('.timeline-dot').className = 'timeline-dot t-done';
    steps[2].querySelector('.timeline-dot').textContent = '✓';
    steps[2].querySelector('.tl').textContent = 'Work submitted for review';
    steps[3].querySelector('.timeline-dot').className = 'timeline-dot t-active';
    steps[3].querySelector('.timeline-dot').textContent = '⚡';
    // Hide submit button
    document.getElementById('submit-work-bar').style.display = 'none';
    showToast('Work submitted! Awaiting client review.', '📤');
  }

  function hireApplicant(name, e) {
    e.stopPropagation();
    showToast(`${name} hired! Funds deducted from your account and locked in escrow.`, '🤝');
  }

  function approveWork() {
    document.getElementById('review-panel').style.display = 'none';
    jobs[1].status = 'done';
    jobs[1].progress = 100;
    document.getElementById('escrow-progress').style.width = '100%';
    document.querySelectorAll('.job-card')[1].querySelector('.badge').className = 'badge badge-completed';
    document.querySelectorAll('.job-card')[1].querySelector('.badge').textContent = 'Done';
    const rc = document.getElementById('review-count');
    rc.textContent = Math.max(0, parseInt(rc.textContent) - 1);
    showToast('✅ Work approved! $3,200 released to freelancer\'s wallet.', '✅');
  }

  function requestRedo() {
    document.getElementById('redo-modal').classList.add('open');
  }

  function confirmRedo() {
    closeModal('redo-modal');
    showToast('🔄 Revision requested. Freelancer has been notified. Funds remain locked.', '🔄');
  }

  function rejectWork() {
    document.getElementById('reject-modal').classList.add('open');
  }

  function confirmReject() {
    closeModal('reject-modal');
    document.getElementById('review-panel').style.display = 'none';
    const rc = document.getElementById('review-count');
    rc.textContent = Math.max(0, parseInt(rc.textContent) - 1);
    showToast('⛔ Job rejected. $3,200 refunded to your wallet.', '⛔');
  }

  function showToast(msg, icon) {
    const t = document.getElementById('toast');
    document.getElementById('toast-msg').textContent = msg;
    document.getElementById('toast-icon').textContent = icon;
    t.classList.remove('hidden');
    setTimeout(() => t.classList.add('hidden'), 4000);
  }

  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', e => { if (e.target === overlay) overlay.classList.remove('open'); });
  });

  // Init: show job 0, which is hiring (no review panel)
  startCountdown(12);
  // Show review panel because job 1 is selected by default? No, job 0 is selected by default
  document.getElementById('review-panel').style.display = 'none';
</script>
</body>
</html>
