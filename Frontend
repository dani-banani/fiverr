  const jobs = [
    { title: 'DeFi Dashboard UI Design', amount: '$2,400', days: 12, progress: 15, applicants: '5 total' },
    { title: 'Smart Contract Audit — ERC-20', amount: '$3,200', days: 9, progress: 45, applicants: '1 hired' },
    { title: 'Blockchain Backend API', amount: '$1,800', days: 14, progress: 5, applicants: '2 total' },
    { title: 'NFT Marketplace Frontend', amount: '$1,050', days: 0, progress: 100, applicants: 'Completed' },
  ];

  function switchRole(role) {
    currentRole = role;
    document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
    event.target.classList.add('active');
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    document.getElementById('view-' + role).classList.add('active');

    if (role === 'client') {
      document.getElementById('nav-username').textContent = 'Alex Chen';
      document.getElementById('nav-avatar').textContent = 'AC';
    } else {
      document.getElementById('nav-username').textContent = 'Jamie Liu';
      document.getElementById('nav-avatar').textContent = 'JL';
    }
  }

  function selectJob(el, idx) {
    document.querySelectorAll('.job-card').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
    currentJobIdx = idx;
    const job = jobs[idx];
    document.getElementById('escrow-val').textContent = job.amount;
    document.getElementById('escrow-sub').textContent = job.title;
    document.getElementById('escrow-progress').style.width = job.progress + '%';
    document.getElementById('applicant-badge').textContent = job.applicants;
    startCountdown(job.days);
  }

  function startCountdown(days) {
    clearInterval(countdownInterval);
    let totalSecs = days * 86400 + Math.floor(Math.random() * 86400);
    function update() {
      const d = Math.floor(totalSecs / 86400);
      const h = Math.floor((totalSecs % 86400) / 3600);
      const m = Math.floor((totalSecs % 3600) / 60);
      document.getElementById('countdown-display').textContent =
        (d > 0 ? d + 'd ' : '') + String(h).padStart(2,'0') + 'h ' + String(m).padStart(2,'0') + 'm';
      if (totalSecs > 0) totalSecs--;
    }
    update();
    countdownInterval = setInterval(update, 60000);
  }

  function openPostJob() {
    document.getElementById('post-job-modal').classList.add('open');
  }

  function closeModal(id) {
    document.getElementById(id).classList.remove('open');
  }

  function updateLockPreview(val) {
    const v = parseFloat(val) || 0;
    const fee = v * 0.03;
    const total = v + fee;
    document.getElementById('breakdown-pay').textContent = '$' + v.toFixed(2);
    document.getElementById('breakdown-fee').textContent = '$' + fee.toFixed(2);
    document.getElementById('breakdown-total').textContent = '$' + total.toFixed(2);
  }

  function postJob() {
    closeModal('post-job-modal');
    showToast('🔒 Job posted! Funds locked in escrow.', '🔒');
  }

  function openApply(title, pay) {
    document.getElementById('apply-job-title').textContent = title;
    document.getElementById('apply-job-pay').textContent = pay;
    document.getElementById('apply-escrow-amt').textContent = pay;
    document.getElementById('apply-modal').classList.add('open');
  }

  function submitApplication() {
    closeModal('apply-modal');
    const title = document.getElementById('apply-job-title').textContent;
    const pay = document.getElementById('apply-job-pay').textContent;
    const list = document.getElementById('my-applications-list');
    const div = document.createElement('div');
    div.className = 'app-row';
    div.innerHTML = `
      <div class="app-avatar" style="width:36px;height:36px;border-radius:8px;background:rgba(251,191,36,0.2);display:flex;align-items:center;justify-content:center;font-size:0.75rem;color:var(--amber);">⏳</div>
      <div class="app-row-info">
        <div class="app-row-title">${title}</div>
        <div class="app-row-company">New Application</div>
      </div>
      <div class="app-row-pay">${pay}</div>
      <span class="badge badge-pending">Pending</span>
    `;
    list.insertBefore(div, list.firstChild);
    showToast('Application submitted! 🎉', '✅');
  }

  function hireApplicant(name) {
    showToast(`${name} hired! Payment will release on delivery.`, '🤝');
  }

  function showToast(msg, icon) {
    const t = document.getElementById('toast');
    document.getElementById('toast-msg').textContent = msg;
    document.getElementById('toast-icon').textContent = icon;
    t.classList.remove('hidden');
    setTimeout(() => t.classList.add('hidden'), 3500);
  }

  // Click outside modal to close
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', e => {
      if (e.target === overlay) overlay.classList.remove('open');
    });
  });

  startCountdown(12);
</script>
</body>
</html>
